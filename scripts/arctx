#!/usr/bin/env bash
# Dev wrapper: run the arctx CLI from this repo's sources (no install needed).
# Used as the hook command in .claude/settings.local.json so Claude Code
# sessions in this repo are recorded even though the packages aren't
# installed. See docs/ja/CLI.md "Claude Code 連携".
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export PYTHONPATH="$REPO_ROOT/packages/arctx/src:$REPO_ROOT/packages/arctx-cli/src${PYTHONPATH:+:$PYTHONPATH}"
# arctx は 3.10+ 必須 (型 union 構文)。システム python3 が 3.9 だと起動失敗するため
# 3.10+ を優先的に選ぶ。
PYBIN="$(command -v python3.12 || command -v python3.11 || command -v python3.10 || command -v python3)"
exec "$PYBIN" -m arctx_cli.main "$@"
